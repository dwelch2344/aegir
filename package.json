{
  "name": "aegir",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "type": "module",
  "scripts": {
    "dev": "turbo dev --ui=stream --log-order=stream --concurrency=15 > log.txt",
    "start": "turbo run start --ui=stream --log-order=stream --concurrency=15 > log.txt",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "shipyard": "node packages/shipyard/dist/cli.js",
    "local:init": "bash scripts/init.sh",
    "local:destroy": "bash scripts/destroy.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "turbo": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ]
  }
}
